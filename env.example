# Copy this file to .env and fill in your actual values.
# .env is in .gitignore — it will NEVER be pushed to GitHub.
# On Railway, add these same keys in the Variables tab instead.

# Get from: aistudio.google.com → Get API Key (free)
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: cloud.qdrant.io → your cluster → Connection details
QDRANT_URL=https://xxxx-xxxx.aws.cloud.qdrant.io

# Get from: cloud.qdrant.io → your cluster → API Keys
QDRANT_API_KEY=your_qdrant_api_key_here

# Optional — default is 500. Lower this if Railway runs out of memory.
MAX_FILES=500
